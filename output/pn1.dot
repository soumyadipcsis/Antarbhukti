digraph PN {
  rankdir=LR;
  node [fontname="Arial"];
  "Init" [shape=circle,label="Init\nHexValue := ''; TempDecValue := DecValue; i := 9" style=filled,fillcolor=lightgray];
  "CheckZero" [shape=circle,label="CheckZero"];
  "SetZero" [shape=circle,label="SetZero\nHexValue := '0'; Convert := True"];
  "CheckRange" [shape=circle,label="CheckRange"];
  "SetError" [shape=circle,label="SetError\nHexValue := 'Error'; Convert := False"];
  "ConvertLoop" [shape=circle,label="ConvertLoop"];
  "BuildHex" [shape=circle,label="BuildHex\nTempHex := TempDecValue mod 16; HexValue := HexValue * 16 + TempHex; TempDecValue := TempDecValue / 16"];
  "CheckExit" [shape=circle,label="CheckExit"];
  "SetSuccess" [shape=circle,label="SetSuccess\nConvert := True"];
  "End" [shape=circle,label="End"];
  "t_0" [shape=rect,width=0.3,height=0.7,label="t_0\n[init]"];
  "t_1" [shape=rect,width=0.3,height=0.7,label="t_1\n[DecValue = 0]"];
  "t_2" [shape=rect,width=0.3,height=0.7,label="t_2\n[True]"];
  "t_3" [shape=rect,width=0.3,height=0.7,label="t_3\n[DecValue <> 0]"];
  "t_4" [shape=rect,width=0.3,height=0.7,label="t_4\n[DecValue > 9999999999]"];
  "t_5" [shape=rect,width=0.3,height=0.7,label="t_5\n[True]"];
  "t_6" [shape=rect,width=0.3,height=0.7,label="t_6\n[DecValue <= 9999999999]"];
  "t_7" [shape=rect,width=0.3,height=0.7,label="t_7\n[i >= 0]"];
  "t_8" [shape=rect,width=0.3,height=0.7,label="t_8\n[True]"];
  "t_9" [shape=rect,width=0.3,height=0.7,label="t_9\n[TempDecValue = 0]"];
  "t_10" [shape=rect,width=0.3,height=0.7,label="t_10\n[True]"];
  "t_11" [shape=rect,width=0.3,height=0.7,label="t_11\n[TempDecValue <> 0; i := i - 1]"];
  "Init" -> "t_0";
  "CheckZero" -> "t_1";
  "SetZero" -> "t_2";
  "CheckZero" -> "t_3";
  "CheckRange" -> "t_4";
  "SetError" -> "t_5";
  "CheckRange" -> "t_6";
  "ConvertLoop" -> "t_7";
  "BuildHex" -> "t_8";
  "CheckExit" -> "t_9";
  "SetSuccess" -> "t_10";
  "CheckExit" -> "t_11";
  "t_0" -> "CheckZero";
  "t_1" -> "SetZero";
  "t_2" -> "End";
  "t_3" -> "CheckRange";
  "t_4" -> "SetError";
  "t_5" -> "End";
  "t_6" -> "ConvertLoop";
  "t_7" -> "BuildHex";
  "t_8" -> "CheckExit";
  "t_9" -> "SetSuccess";
  "t_10" -> "End";
  "t_11" -> "ConvertLoop";
}
