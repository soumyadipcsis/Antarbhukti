digraph SFC {
  rankdir=LR;
  node [fontname="Arial"];
  "Init" [shape=box,label="Init\nHexValue := ''; TempDecValue := DecValue; i := 9" style=filled,fillcolor=lightblue];
  "CheckZero" [shape=box,label="CheckZero\n"];
  "SetZero" [shape=box,label="SetZero\nHexValue := '0'; Convert := True"];
  "CheckRange" [shape=box,label="CheckRange\n"];
  "SetError" [shape=box,label="SetError\nHexValue := 'Error'; Convert := False"];
  "ConvertLoop" [shape=box,label="ConvertLoop\n"];
  "BuildHex" [shape=box,label="BuildHex\nTempHex := TempDecValue mod 16; HexValue := HexValue * 16 + TempHex; TempDecValue := TempDecValue / 16"];
  "CheckExit" [shape=box,label="CheckExit\n"];
  "SetSuccess" [shape=box,label="SetSuccess\nConvert := True"];
  "End" [shape=box,label="End\n"];
  "TR_1" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="init"];
  "TR_2" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="DecValue = 0"];
  "TR_3" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="True"];
  "TR_4" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="DecValue <> 0"];
  "TR_5" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="DecValue > 9999999999"];
  "TR_6" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="True"];
  "TR_7" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="DecValue <= 9999999999"];
  "TR_8" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="i >= 0"];
  "TR_9" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="True"];
  "TR_10" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="TempDecValue = 0"];
  "TR_11" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="True"];
  "TR_12" [shape=rect,style=bold,penwidth=3,width=0.2,height=0.5,label="TempDecValue <> 0; i := i - 1"];
  "Init" -> "TR_1";
  "TR_1" -> "CheckZero";
  "CheckZero" -> "TR_2";
  "TR_2" -> "SetZero";
  "SetZero" -> "TR_3";
  "TR_3" -> "End";
  "CheckZero" -> "TR_4";
  "TR_4" -> "CheckRange";
  "CheckRange" -> "TR_5";
  "TR_5" -> "SetError";
  "SetError" -> "TR_6";
  "TR_6" -> "End";
  "CheckRange" -> "TR_7";
  "TR_7" -> "ConvertLoop";
  "ConvertLoop" -> "TR_8";
  "TR_8" -> "BuildHex";
  "BuildHex" -> "TR_9";
  "TR_9" -> "CheckExit";
  "CheckExit" -> "TR_10";
  "TR_10" -> "SetSuccess";
  "SetSuccess" -> "TR_11";
  "TR_11" -> "End";
  "CheckExit" -> "TR_12";
  "TR_12" -> "ConvertLoop";
  init [shape=point, width=0.2, color=black];
  init -> "Init" [arrowhead=normal];
}
